<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ report_title }} - {{ report_date_iso }}</title>
    {% if inline_styles %}
    <style>
{{ inline_styles | safe }}
    </style>
    {% else %}
    <link rel="stylesheet" href="{{ stylesheet_href }}">
    {% endif %}
</head>
<body>
    <div class="header">
        <h1>📊 {{ report_title }}</h1>
        <div class="date">报告日期：{{ report_generated_at }} (北京时间) | 版本: {{ report_version }}</div>
    </div>

    {{ market_overview_section | safe }}
    {{ market_insights_section | safe }}
    {{ technical_context_section | safe }}

    <div class="section">
        <h2>主要加密货币表现</h2>
        {{ top_focus_assets_section | safe }}
        <div class="crypto-table">
            <table>
                <thead>
                    <tr>
                        <th>排名</th>
                        <th>名称</th>
                        <th>价格</th>
                        <th>24h涨跌</th>
                        <th>7天涨跌</th>
                        <th>市值</th>
                        <th>24h交易量</th>
                    </tr>
                </thead>
                <tbody>
                    {{ crypto_table_rows | safe }}
                </tbody>
            </table>
        </div>
    </div>

    <div class="section">
        <h2>重要新闻 <span class="news-date-range">({{ news_date_range }})</span></h2>
        {{ news_html | safe }}
    </div>

    {{ sentiment_section | safe }}
    {{ ai_analysis_section | safe }}
    {{ financial_analyst_section | safe }}

    <div class="section">
        <h2>风险提示</h2>
        <p class="stance-row">加密货币市场波动性极高，投资需谨慎。本分析仅供参考，不构成投资建议。投资者应根据自身风险承受能力和投资目标做出独立决策。过去表现不代表未来结果，加密货币投资可能面临本金损失风险。</p>
    </div>

    <div class="footer">
        <p><strong>报告系统：{{ report_system_name }}</strong> | 数据来源：市场公开数据 + AI分析</p>
        <p>访问地址：{{ report_base_url }}</p>
    </div>
</body>
</html>
